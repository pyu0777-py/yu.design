    <div class="lightbox-overlay" id="lightboxOverlay">
        <div class="lightbox-content">
            <button class="lightbox-close" id="lightboxClose" aria-label="关闭">×</button>
            <button class="lightbox-nav prev" id="lightboxPrev" aria-label="上一张">‹</button>
            <img id="lightboxImage" src="" alt="作品大图">
            <button class="lightbox-nav next" id="lightboxNext" aria-label="下一张">›</button>
            <div class="lightbox-caption" id="lightboxCaption"></div>
        </div>
    </div>

    <script>
        // === 平滑滚动 ===
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const href = anchor.getAttribute('href');
                const target = href ? document.querySelector<HTMLElement>(href) : null;
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // === 作品过滤功能 ===
        function filterWorks(type: string, button: HTMLElement | null) {
            const cards = document.querySelectorAll<HTMLElement>('.project-card');
            const buttons = document.querySelectorAll<HTMLElement>('.filter-btn');

            buttons.forEach(btn => btn.classList.remove('active'));
            if (button) {
                button.classList.add('active');
            }

            cards.forEach(card => {
                if (type === 'all' || card.dataset.type === type) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        document.querySelectorAll<HTMLElement>('.filter-btn').forEach(button => {
            button.addEventListener('click', () => {
                filterWorks(button.dataset.filter || 'all', button);
            });
        });

        const chartPreview = document.getElementById('chartPreview');
        const overlay = document.getElementById('lightboxOverlay');
        const lightboxImage = document.getElementById('lightboxImage') as HTMLImageElement | null;
        const lightboxCaption = document.getElementById('lightboxCaption');
        const lightboxClose = document.getElementById('lightboxClose');
        const lightboxPrev = document.getElementById('lightboxPrev');
        const lightboxNext = document.getElementById('lightboxNext');
        let currentLightboxImages: string[] = [];
        let currentLightboxIndex = 0;

        function openLightbox(images: string[], index = 0) {
            if (!overlay || !lightboxImage || !lightboxCaption) return;
            currentLightboxImages = images;
            currentLightboxIndex = index;
            lightboxImage.src = images[index] || '';
            lightboxCaption.textContent = `作品图 ${index + 1}/${images.length}`;
            overlay.classList.add('active');
        }

        function closeLightbox() {
            if (overlay) overlay.classList.remove('active');
        }

        function showLightboxImage(index: number) {
            if (!lightboxImage || !lightboxCaption || !currentLightboxImages.length) return;
            currentLightboxIndex = (index + currentLightboxImages.length) % currentLightboxImages.length;
            lightboxImage.src = currentLightboxImages[currentLightboxIndex];
            lightboxCaption.textContent = `作品图 ${currentLightboxIndex + 1}/${currentLightboxImages.length}`;
        }

        function getProjectGalleryImages(card: HTMLElement) {
            const baseImages = [
                'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1495707902641-75cac588d2e9?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=600&q=80'
            ];
            const customImages = JSON.parse(card.dataset.images || '[]') as string[];
            const sourceImages = customImages.length ? customImages : baseImages;
            return Array.from({ length: 25 }, (_, index) => `${sourceImages[index % sourceImages.length]}&sig=${index}`);
        }

        document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
            card.addEventListener('click', () => {
                const isExpanded = card.classList.contains('expanded');
                document.querySelectorAll<HTMLElement>('.project-card').forEach(otherCard => {
                    otherCard.classList.remove('expanded');
                    const gallery = otherCard.querySelector<HTMLElement>('.project-gallery');
                    if (gallery) gallery.innerHTML = '';
                });

                if (!isExpanded) {
                    card.classList.add('expanded');
                    const images = getProjectGalleryImages(card);
                    const gallery = card.querySelector<HTMLElement>('.project-gallery');
                    if (gallery && images.length) {
                        const previewImages = images.slice(0, 2);
                        gallery.innerHTML = `
                            <div class="project-gallery-preview compact-preview">
                                <div class="main-preview"><img src="${previewImages[0]}" alt="作品主图"></div>
                                <div class="main-preview secondary-preview"><img src="${previewImages[1]}" alt="作品辅助图"></div>
                            </div>
                        `;
                        gallery.querySelectorAll<HTMLImageElement>('img').forEach((img, index) => {
                            img.addEventListener('click', (event) => {
                                event.stopPropagation();
                                openLightbox(images, index);
                            });
                        });
                    }
                }
            });
        });

        document.querySelectorAll<HTMLElement>('.rank-item').forEach(item => {
            item.addEventListener('click', () => {
                const isExpanded = item.classList.contains('expanded');
                document.querySelectorAll<HTMLElement>('.rank-item').forEach(otherItem => {
                    otherItem.classList.remove('expanded');
                    const gallery = otherItem.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery) gallery.innerHTML = '';
                });

                if (!isExpanded) {
                    item.classList.add('expanded');
                    const images = JSON.parse(item.dataset.images || '[]') as string[];
                    const gallery = item.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery && images.length) {
                        const displayImages = Array.from({ length: 25 }, (_, index) => `${images[index % images.length]}&sig=${index}`);
                        gallery.innerHTML = displayImages.slice(0, 10).map((src, index) => {
                            if (index === 9) {
                                return `<div class="gallery-more">+${displayImages.length - 9} 张</div>`;
                            }
                            return `<img src="${src}" alt="爆款案例图片" data-index="${index}">`;
                        }).join('');
                        gallery.querySelectorAll<HTMLImageElement>('img').forEach((img, index) => {
                            img.addEventListener('click', (event) => {
                                event.stopPropagation();
                                openLightbox(displayImages, index);
                            });
                        });
                    }
                }
            });
        });

        if (chartPreview) {
            chartPreview.addEventListener('click', () => {
                openLightbox([
                    'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1400&q=80'
                ], 0);
            });
        }

        if (overlay) {
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) closeLightbox();
            });
        }
        if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
        if (lightboxPrev) lightboxPrev.addEventListener('click', () => showLightboxImage(currentLightboxIndex - 1));
        if (lightboxNext) lightboxNext.addEventListener('click', () => showLightboxImage(currentLightboxIndex + 1));
        document.addEventListener('keydown', (event) => {
            if (!overlay?.classList.contains('active')) return;
            if (event.key === 'Escape') closeLightbox();
            if (event.key === 'ArrowRight') showLightboxImage(currentLightboxIndex + 1);
            if (event.key === 'ArrowLeft') showLightboxImage(currentLightboxIndex - 1);
        });

        // === 原生 JS 数字滚动动画 ===
        function animateCountUp(el: HTMLElement) {
            const target = parseInt(el.dataset.target || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 2000; // 2秒动画
            const step = target / (duration / 16); // 每帧增加的数值
            let current = 0;

            const timer = setInterval(() => {
                current += step;
                if (current >= target) {
                    el.innerText = target + suffix;
                    clearInterval(timer);
                } else {
                    el.innerText = Math.ceil(current) + suffix;
                }
            }, 16);
        }

        // === 监听滚动触发数字动画 ===
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting && entry.target instanceof HTMLElement) {
                    animateCountUp(entry.target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.count-up').forEach(el => observer.observe(el));

        // === 编辑模式开关 ===
        let clickCount = 0;
        let clickTimer: ReturnType<typeof setTimeout> | null = null;
        const logo = document.getElementById('logo-trigger');
        const indicator = document.getElementById('edit-mode-indicator');

        if (logo) {
            logo.addEventListener('click', () => {
                clickCount++;
                if (clickCount === 1) {
                    clickTimer = setTimeout(() => {
                        clickCount = 0;
                    }, 1000); // 1秒内点击3次
                } else if (clickCount === 3) {
                    if (clickTimer) clearTimeout(clickTimer);
                    clickCount = 0;
                    
                    const isEditable = document.body.contentEditable === 'true';
                    document.body.contentEditable = isEditable ? 'false' : 'true';
                    
                    if (indicator) {
                        indicator.style.display = isEditable ? 'none' : 'block';
                        setTimeout(() => {
                            if (!isEditable && indicator) indicator.style.display = 'none';
                        }, 2000);
                    }
                }
            });
        }
    </script>
</body>
</html>